{
  "cleanUrls": true,
  "functions": {
    "api/index.py": {
      "excludeFiles": "{.venv/**,__pycache__/**,test_*.py,*.backup-*.xlsx,dashboard_auth.sqlite3}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py?path=:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
